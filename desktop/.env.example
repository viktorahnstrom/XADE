# Copy to desktop/.env for local dev. The Vite build inlines anything
# starting with VITE_ at build time, so production values come from the
# Vercel project's Environment Variables panel — not this file.

# Supabase project (study_results table writes use the anon key with RLS).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend FastAPI base URL.
# - Local dev:        http://localhost:8000
# - Vercel preview:   https://xade-backend-staging.up.railway.app
# - Vercel production: https://xade-backend.up.railway.app
VITE_API_BASE_URL=http://localhost:8000
