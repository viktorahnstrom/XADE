# Copy to desktop/.env for local dev. The Vite build inlines anything
# starting with VITE_ at build time, so production values come from the
# Vercel project's Environment Variables panel — not this file.

# Supabase project (study_results table writes use the anon key with RLS).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Production deploys the study-only experience (defaults to true). Set to
# false locally to bring back the full app (auth + image upload + product
# trial) while developing.
VITE_STUDY_ONLY=false

# Backend FastAPI base URL — only used when VITE_STUDY_ONLY=false.
# - Local dev:        http://localhost:8000
# - Production:       https://xade-backend.up.railway.app
VITE_API_BASE_URL=http://localhost:8000
