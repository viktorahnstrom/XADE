# ====================
# ML/Dataset specific
# ====================

# Dataset directories - DO NOT COMMIT
data/
backend/data/
**/data/
140k-real-and-fake-faces/
faceforensics_frames/
real_vs_fake/

# Archives
*.zip
*.tar.gz
*.rar
*.7z
*.gz

# Model checkpoint files (large) - DO NOT COMMIT
*.pt
*.pth
*.ckpt
*.h5
*.pkl
*.pickle
*.safetensors
*.bin
*.task

# BUT keep checkpoint metadata (small JSON files)
!backend/checkpoints/*.json
!checkpoints/*.json

# Result files - keep metadata, ignore large files
backend/results/*.mp4
backend/results/*.avi
results/*.mp4
results/*.avi

# Training/experiment tracking
runs/
outputs/
logs/
wandb/
tensorboard/
mlruns/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Large data files
*.csv
!**/requirements*.txt
!**/requirements*.csv

# ====================
# Evaluation results
# ====================

# Generated result JSONs - do not commit, reproducible from scripts
backend/results/*.json
results/*.json

# Accidental nested backend folder
backend/backend/
node_modules/.package-lock.json

# Reproducible CAM comparison artifacts (regenerate with backend/scripts/compare_cams.py)
backend/tests/fixtures/cam_comparison/*.png

# Planning docs — kept locally, not tracked
docs/vlm-grounding-roadmap.md
